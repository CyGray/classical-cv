# ===================================
outputs/
**/outputs/
reports/evaluation/*.json
reports/evaluation/*.txt
reports/evaluation/**/*.json
reports/evaluation/**/*.txt
reports/benchmark/*.json
reports/benchmark/*.md
reports/benchmark/**/*.json
reports/benchmark/**/*.jsonl
reports/benchmark/live_fps/

# Local model pack generated during ArcFace experiments
models/arcface_mobilenet/

